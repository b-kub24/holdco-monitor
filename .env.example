# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Zapier Webhook for Telegram alerts (Clawdbot)
ZAPIER_WEBHOOK_URL=https://hooks.zapier.com/hooks/catch/YOUR_ID/YOUR_HOOK/

# Vercel Cron Secret (set in Vercel dashboard)
CRON_SECRET=your-cron-secret

# Optional: Override check interval (default 15 min)
# CHECK_INTERVAL_MINUTES=15
